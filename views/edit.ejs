<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.css" rel="stylesheet">
    <title>Document</title>
</head>

<body>
    <!-- The main container -->
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block" href="/logout">logout</a>
        </div>
        <a href="/profile" class="text-blue-500 hover:underline">Back to Profile</a>
        <h5 class="">Edit Post</h5>

        <form action="/update/<%= post._id %>" method="post" class="flex flex-col gap-5 mt-5">
            <textarea name="content" id="" placeholder="what's on your mind"
                class="w-1/3 resize-none bg-transparent border-2 border-zinc-600 p-2 rounded-md"><%= post.content %></textarea>

            <input type="submit" class="w-40 px-3 py-2 bg-green-500 rounded-md text-sm" value="Update Post">
        </form>
    </div>
</body>

</html>
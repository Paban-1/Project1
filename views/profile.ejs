<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
</head>

<body>
    <!-- The main container -->
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block" href="/logout">logout</a>
        </div>

        <h3 class="text-3xl mb-5"> <span class="font-liht">Hello,</span>
            <%= user.username %>👋
        </h3>

        <h5 class="">You can create Post</h5>

        <form action="/post" method="post" class="flex flex-col gap-5 mt-5">
            <textarea name="content" id="" placeholder="what's on your mind"
                class="w-1/3 resize-none bg-transparent border-2 border-zinc-600 p-2 rounded-md"></textarea>

            <input type="submit" class="w-40 px-3 py-2 bg-blue-500 rounded-md text-sm" value="Create new post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinc-400">Your posts.</h3>
            <div class="postcontaner flex gap-2 mt-5 flex-wrap">

                <% user.posts.reverse().forEach(function(post){ %>
                    <div class="w-1/3 p-4 rounded-md border-[1px] border-zinc-700 bg-zinc-800">

                        <h4 class="text-blue-500 mb-2">@<%= user.username %>
                        </h4>
                        <p class="text-sm tracking-tighter">
                            <%= post.content %>
                        </p>
                        <div class="btns flex mt-5 justify-between">
                            <a class="text-blue-500" href="">Like</a>

                            <a class="text-zinc-400" href="">Edit</a>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
    </div>
</body>

</html>
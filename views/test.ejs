<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
</head>

<body>
    <!-- The main container -->
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <h3 class="text-2xl font-bold mb-6">Upload Your Files</h3>

        <!-- Form -->
        <form autocomplete="off" action="/upload"  method="post" enctype="multipart/form-data">
            <!-- input  -->
            <input type="file" name="image">

            <!-- Submit button -->
            <input class="px-5 py-2 rounded-xl bg-blue-500" type="submit" value="Upload Files">
        </form>
    </div>
</body>

</html>
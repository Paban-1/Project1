<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
</head>

<body>
    <!-- The main container -->
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <h3 class="text-2xl font-bold mb-6">login to Your Account</h3>

        <!-- Form -->
        <form action="/login" method="post">

            <!-- Email input -->
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" type="email"
                name="email" placeholder="Enter Email">

            <!-- Password input -->
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" type="password"
                name="password" placeholder="Enter Password">

            <!-- Submit button -->
            <input class="px-5 py-2 rounded-xl bg-yellow-500" type="submit" value="login Account">
        </form>
    </div>
</body>

</html>